# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=abiyan_telestore

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
# DATABASE_URL is auto-constructed in docker-compose.yml from the values above.
SECRET_KEY=change-this-to-a-random-32-char-secret-key
REFRESH_SECRET_KEY=change-this-to-a-different-random-32-char-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5174
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]

# ── Frontend build arg ────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
